# 复制为 .env 后填写
# 本地优先模式（优先本地依赖与本地推理，减少云端依赖）
LOCAL_FIRST_MODE=true
# 是否允许远端 LLM（false 时禁用云端问答，仅用本地知识检索/规则回复）
LLM_REMOTE_ENABLED=true

LLM_API_KEY=your_deepseek_api_key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-chat
# 浏览器连接配置（跨平台）
BROWSER_PORT=9222
USER_DATA_PATH=./user_data
# 可选：自定义 Chrome 可执行文件路径（Windows/macOS）
# CHROME_EXECUTABLE=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# CHROME_EXECUTABLE=C:\Program Files\Google\Chrome\Application\chrome.exe
# 可选：浏览器调试启动附加参数（Windows 推荐按需保留空）
# CHROME_DEBUG_EXTRA_ARGS=--disable-gpu --lang=zh-CN
# 启动阶段重试配置
STARTUP_CONNECT_RETRIES=3
STARTUP_CONNECT_RETRY_INTERVAL_SECONDS=1.0
STARTUP_THREAD_READY_TIMEOUT_SECONDS=0.25
# 回复速度参数
REPLY_INTERVAL_SECONDS=0.35
LLM_REQUEST_TIMEOUT_SECONDS=3.5
LLM_MIN_INTERVAL_SECONDS=0.8
MAX_MESSAGES_PER_CYCLE=3
MAIN_LOOP_BUSY_INTERVAL_SECONDS=0.16
MAIN_LOOP_IDLE_INTERVAL_SECONDS=0.32
MAIN_LOOP_ERROR_BACKOFF_SECONDS=0.7
# 向量化模型（默认仓库名）。在离线快速模式下建议改为本地模型目录路径。
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# true: 仅使用本地模型（启动快，不联网）；false: 允许在线拉取模型
EMBEDDING_LOCAL_FILES_ONLY=true
# 当 local-only 失败时，是否再尝试联网下载（可能导致启动变慢）
EMBEDDING_ENABLE_ONLINE_FALLBACK=false
# 可选：本地模型缓存目录
EMBEDDING_CACHE_DIR=
HF_HUB_ETAG_TIMEOUT_SECONDS=2
HF_HUB_DOWNLOAD_TIMEOUT_SECONDS=8
# 仅允许这些用户名触发“置顶/秒杀上架”口令（逗号分隔，填弹幕显示名）
COMMAND_ALLOWED_USERS=YourHostName
# 是否启用“运营口令发言人白名单”校验（默认 false：不限制发送者）
COMMAND_REQUIRE_ALLOWED_USERS=false
# 弹幕运营动作冷却（秒）：防止同一动作在短时间被重复触发
DANMU_COMMAND_COOLDOWN_SECONDS=6
# screen_ocr 模式下是否要求弹幕包含唤醒词（助播/assistant/...）才执行运营动作
SCREEN_OCR_DANMU_REQUIRE_WAKE_WORD=true
# 页面操作模式：dom / ocr_vision
# 默认推荐 ocr_vision；dom 仅在你明确需要时手动开启
OPERATION_EXECUTION_MODE=ocr_vision
# OCR视觉模式门禁（仅在 OPERATION_EXECUTION_MODE=ocr_vision 时生效）
OCR_VISION_PRECHECK_ENABLED=true
OCR_VISION_REQUIRED_KEYWORDS=直播控制台,商品,活动,chat,viewer
# OCR视觉模式是否允许 DOM 回退（默认关闭，确保未显式选择时不走 DOM）
OCR_VISION_ALLOW_DOM_FALLBACK=false
# 拟人化执行（键鼠节奏随机化）
HUMAN_LIKE_ACTION_ENABLED=true
HUMAN_LIKE_ACTION_DELAY_MIN_SECONDS=0.04
HUMAN_LIKE_ACTION_DELAY_MAX_SECONDS=0.20
HUMAN_LIKE_ACTION_POST_DELAY_MIN_SECONDS=0.03
HUMAN_LIKE_ACTION_POST_DELAY_MAX_SECONDS=0.16
HUMAN_LIKE_CLICK_JITTER_PX=1.8
# 强制全链路物理键鼠执行（开启后禁用 DOM 点击/表单提交回退）
FORCE_FULL_PHYSICAL_MOUSE_KEYBOARD=false
# OCR点击后“无反应再二次处理”的等待窗口（秒）
OCR_ACTION_RETRY_WAIT_SECONDS=30
OCR_ACTION_RETRY_POLL_SECONDS=0.65
# 点击后新文本/新窗口变化是否交给LLM做判定（建议开启）
OCR_ACTION_REACTION_LLM_ENABLED=true
OCR_ACTION_REACTION_LLM_MAX_CHECKS=4
OCR_ACTION_REACTION_LLM_MIN_INTERVAL_SECONDS=1.2
# 运营动作 run_js 限时（用于压制跨frame卡顿）
OPS_RUN_JS_TIMEOUT_SECONDS=1.2
OPS_RUN_JS_FALLBACK_TIMEOUT_SECONDS=0.45
OPS_RUN_JS_MAX_CONTEXTS=3
# run_js 是否遍历 frame（关闭可显著降低单步固定 10s 卡顿）
OPS_RUN_JS_INCLUDE_FRAMES=false
# 从 tiktok.com/live/dashboard 自动跳转到可执行的 Shop 控制台页（逗号分隔）
ACTION_PAGE_SHOP_DASHBOARD_URLS=https://shop.tiktok.com/streamer/live/product/dashboard
# 输入框回退：当DOM写入不稳定时，改用系统键盘逐字符输入（默认关闭）
OS_KEYBOARD_INPUT_FALLBACK_ENABLED=false
OS_KEYBOARD_TYPING_MIN_INTERVAL_SECONDS=0.018
OS_KEYBOARD_TYPING_MAX_INTERVAL_SECONDS=0.055
# 消息发送链路是否强制走键盘模拟（回复与自动暖场都生效）
MESSAGE_KEYBOARD_ONLY_ENABLED=true
# 键盘输入模式：type=手打，paste=粘贴，auto=短文本手打+长文本粘贴
MESSAGE_KEYBOARD_INPUT_MODE=type
# 运营动作受限计划器（LLM仅规划；默认影子模式：记录计划但仍走既有执行链路）
OPS_LLM_PLAN_ENABLED=false
OPS_LLM_PLAN_SHADOW_MODE=true
OPS_LLM_PLAN_MAX_STEPS=3
OPS_LLM_PLAN_MAX_RETRIES=1
OPS_LLM_PLAN_TIMEOUT_SECONDS=18
OPS_LLM_PLAN_MIN_CONFIDENCE=0.55
OPS_LLM_PLAN_NEXT_STEP_ENABLED=true
OPS_LLM_PLAN_NEXT_STEP_MAX_TURNS=6
OPS_LLM_PLAN_NEXT_STEP_MIN_CONFIDENCE=0.50
OPS_LLM_PLAN_SITUATION_DRIVEN=true
OPS_LLM_PLAN_REPLAY_PATH=data/reports/operation_plan_replay.jsonl
# 运营动作 LLM 导航兜底（仅在规则链未命中时触发）
OPS_LLM_NAVIGATION_ENABLED=true
# 遇到未见过页面时，允许 LLM 依据 OCR 语义判定是否可执行
OPS_LLM_NAVIGATION_UNKNOWN_PAGE_ENABLED=true
OPS_LLM_NAVIGATION_MIN_CONFIDENCE=0.58
OPS_LLM_NAVIGATION_MAX_SCROLL_ROUNDS=6
OPS_LLM_NAVIGATION_MAX_LLM_CALLS=3
OPS_LLM_NAVIGATION_MIN_INTERVAL_SECONDS=0.9
OPS_LLM_NAVIGATION_SCROLL_COOLDOWN_SECONDS=0.32
OPS_LLM_NAVIGATION_SCROLL_PIXELS=520
# 网页信息读取模式：dom / ocr_hybrid / ocr_only / screen_ocr
# screen_ocr = 完全不读取浏览器 DOM 文本，只做屏幕OCR识别
WEB_INFO_SOURCE_MODE=ocr_only
OCR_CHAT_MAX_MESSAGES=6
# 纯屏幕OCR时的显示器索引（mss: 1=主屏）
SCREEN_CAPTURE_MONITOR_INDEX=1
# 纯屏幕OCR弹幕固定区域（相对整屏比例，优先用于聊天抓取）
SCREEN_OCR_FIXED_CHAT_REGION_ENABLED=true
SCREEN_OCR_FIXED_CHAT_REGION_X1_RATIO=0.44
SCREEN_OCR_FIXED_CHAT_REGION_Y1_RATIO=0.43
SCREEN_OCR_FIXED_CHAT_REGION_X2_RATIO=0.72
SCREEN_OCR_FIXED_CHAT_REGION_Y2_RATIO=0.90
# 聊天ROI可视化调试（保存整屏框选图+ROI裁剪图）
SCREEN_OCR_CHAT_ROI_DEBUG_ENABLED=false
SCREEN_OCR_CHAT_ROI_DEBUG_DIR=logs/screen_chat_roi_debug
SCREEN_OCR_CHAT_ROI_DEBUG_INTERVAL_SECONDS=2.0
SCREEN_OCR_CHAT_ROI_DEBUG_MAX_FILES=240
# 过滤自己账号（防止系统把自己发言当作新弹幕再次回复）
SELF_USERNAMES=YourBotAccount
SELF_ECHO_IGNORE_ENABLED=true
SELF_ECHO_TTL_SECONDS=180
SELF_ECHO_MIN_CHARS=10
# 直播标签页选择策略
TIKTOK_FORCE_LIVE_TAB=true
TIKTOK_TAB_MIN_SCORE=3
TIKTOK_TAB_REQUIRED_KEYWORDS=tiktok,live,直播
TIKTOK_TAB_EXCLUDE_KEYWORDS=google 搜索,new tab,新标签页
# 语音口令监听（物理听到主播说话）
VOICE_COMMAND_ENABLED=false
# 语音输入模式：
# - python_asr: 本地 Python 麦克风采集 + ASR（仅依赖系统麦克风权限）
# - system_loopback_asr: 系统回采（直接识别浏览器播放声音；需系统存在回采输入设备）
# - tab_audio_asr: 直接抓取网页播放器音频流（不录屏、不录麦，推荐）
# - web_speech: 浏览器 Web Speech（依赖 TikTok 网页站点权限）
VOICE_COMMAND_INPUT_MODE=python_asr
# Python ASR 提供商：whisper_local / auto / dashscope_funasr / google / sphinx
VOICE_PYTHON_ASR_PROVIDER=whisper_local
# 当 provider=dashscope_funasr 时，强制使用系统回采（loopback），不走本地麦克风
VOICE_DASHSCOPE_FORCE_LOOPBACK=true
# 允许 Google 云端回退（provider=whisper_local/auto 时可作为兜底）
VOICE_ASR_ALLOW_GOOGLE_FALLBACK=false
# 允许阿里云 FunASR 云端回退（需配置 key）
VOICE_ASR_ALLOW_DASHSCOPE_FALLBACK=false
# 阿里云 Key（可直接复用 DASHSCOPE_API_KEY）
VOICE_DASHSCOPE_API_KEY=
VOICE_DASHSCOPE_MODEL=paraformer-realtime-v2
VOICE_DASHSCOPE_SAMPLE_RATE=16000
# 国内默认可留空；新加坡站可配置：
# VOICE_DASHSCOPE_BASE_WEBSOCKET_API_URL=wss://dashscope-intl.aliyuncs.com/api-ws/v1/inference
VOICE_DASHSCOPE_BASE_WEBSOCKET_API_URL=
# 语言提示（可选）：zh,en,yue,ja
VOICE_DASHSCOPE_LANGUAGE_HINTS=
VOICE_DASHSCOPE_ENABLE_PUNCTUATION=true
VOICE_DASHSCOPE_DISABLE_ITN=false
# 浏览器内播放器流（tab media stream）分段与拼接参数：
# 增大 chunk 可减少“短句碎片”，代价是输出延迟更高。
VOICE_TAB_AUDIO_CHUNK_SECONDS=4.8
VOICE_TAB_AUDIO_MAX_CHUNK_SECONDS=9.0
VOICE_TAB_AUDIO_CHUNK_OVERLAP_SECONDS=0.6
VOICE_TAB_AUDIO_EMIT_IDLE_SECONDS=1.2
VOICE_TAB_AUDIO_EMIT_MAX_WAIT_SECONDS=9.0
VOICE_TAB_AUDIO_EMIT_MAX_CHARS=96
VOICE_TAB_AUDIO_SILENCE_RMS=110
# 是否在 tab 流 ASR 层启用“低质量长句过滤”（建议 false，避免长句被砍成单词）
VOICE_TAB_AUDIO_FILTER_LOW_QUALITY=false
# tab 流本地 whisper 的无语音阈值（越低越不容易漏掉弱音）
VOICE_TAB_AUDIO_WHISPER_NO_SPEECH_THRESHOLD=0.35
# whisper 每轮最多尝试语言数（建议 1，显著降低延迟）
VOICE_WHISPER_MAX_LANGS=1
# 通用 whisper 无语音阈值
VOICE_WHISPER_NO_SPEECH_THRESHOLD=0.50
VOICE_PYTHON_LISTEN_TIMEOUT_SECONDS=2.5
VOICE_PYTHON_PHRASE_TIME_LIMIT_SECONDS=4.0
VOICE_PYTHON_AMBIENT_ADJUST_SECONDS=0.25
VOICE_PYTHON_ENERGY_THRESHOLD=280
VOICE_PYTHON_DYNAMIC_ENERGY=true
# no_text 告警的最小音量阈值（低于该 RMS 只计数不报错）
VOICE_PYTHON_NO_TEXT_WARN_RMS=120
VOICE_PYTHON_MIC_DEVICE_INDEX=-1
VOICE_PYTHON_MIC_DEVICE_NAME_HINT=
# system_loopback_asr 模式下可单独指定回采设备（如 BlackHole / Stereo Mix / VB-CABLE）
VOICE_LOOPBACK_DEVICE_INDEX=-1
VOICE_LOOPBACK_DEVICE_NAME_HINT=blackhole,stereo mix,loopback,vb-cable
# 语音识别轮询间隔（秒）
VOICE_COMMAND_POLL_INTERVAL_SECONDS=0.6
# 语音长时间静默后自动重启阈值（秒）
VOICE_COMMAND_SILENCE_RESTART_SECONDS=18
# 字幕兜底识别（当麦克风识别不稳定时）
VOICE_SUBTITLE_FALLBACK_ENABLED=false
# 语音语言回退链（逗号分隔）
VOICE_COMMAND_FALLBACK_LANGUAGES=zh-CN,en-US
# 语音唤醒词（中英文，默认已内置；如需自定义可覆盖）
VOICE_COMMAND_WAKE_WORDS=助播,主播助手,assistant,cohost,live assistant,stream assistant
# 是否强制要求唤醒词；false 时识别到明确“置顶/秒杀”指令也会执行
VOICE_STRICT_WAKE_WORD=false
# 数据分析自动报表
ANALYTICS_AUTO_REPORT_ENABLED=true
ANALYTICS_REPORT_CHECK_INTERVAL_SECONDS=300

# 控制台服务地址（EXE/服务脚本通用）
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8501
# EXE 启动后自动打开控制台页面
DASHBOARD_AUTO_OPEN=true
# EXE 自动开浏览器前等待 Streamlit 启动的秒数
DASHBOARD_OPEN_BROWSER_TIMEOUT_SECONDS=45
